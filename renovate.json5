{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  kubernetes: {
    managerFilePatterns: [
      '/k8s/manifests/.+\\.yaml$/',
    ],
  },
  flux: {
    managerFilePatterns: [
      '/k8s/manifests/.+\\.yaml$/',
    ],
  },
  terraform: {
    managerFilePatterns: [
      '/\\.tf$/',
    ],
  },
  packageRules: [
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["kube-prometheus-stack"],
      schedule: ["* 0 * * 0"]
    }
  ],
  customManagers: [
    {
      customType: "regex",
      description: "Update CloudNativePG Cluster image references",
      managerFilePatterns: ["**/*.yaml"],
      matchStrings: [
        "kind:\\s+Cluster\\n(?:[^\\n]*\\n)*?\\s+imageName:\\s+(?<depName>[^:]+):(?<currentValue>[^\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
      ],
      datasourceTemplate: "docker",
      versioningTemplate: "docker",
    },
    {
      customType: "regex",
      description: "Update CloudNativePG Cluster image references",
      managerFilePatterns: ["**/*.yaml"],
      matchStrings: [
        "kind:\\s+Cluster\\n(?:[^\\n]*\\n)*?\\s+image:\\s*\\n\\s+reference:\\s+(?<depName>[^:]+):(?<currentValue>[^\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      datasourceTemplate: "docker",
      versioningTemplate: "regex:^pg(?<major>\\d+)-v((?<minor>\\d+))\\.((?<patch>\\d+))\\.((?<build>\\d+))$",
    },
    {
      "customType": "jsonata",
      "description": "Update versioned apko packages via Repology",
      "fileFormat": "yaml",
      "managerFilePatterns": ["/\\.ya?ml$/"],
      "matchStrings": [
         "(contents.packages.{ 'depName': 'alpine_' & $replace($match($$.contents.repositories[0], /alpine\\/v(\\d+\\.\\d+)/)[0].groups[0], '.', '_') & '/' & $substringBefore($, '='), 'currentValue': $substringAfter($, '=') }[currentValue != depName])",
      ],
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose"
    },
    {
      "customType": "jsonata",
      "description": "Update melange versions when using GH releases",
      "fileFormat": "yaml",
      "managerFilePatterns": ["/\\.ya?ml$/"],
      "matchStrings": [
         "pipeline[uses = 'fetch'].with[$contains(uri, 'https://github.com') and $contains(uri, '/releases/download/v${{package.version}}')].{'depName': $match(uri, /https:\\/\\/github\\.com\\/([^\\/]+\\/[^\\/]+)\\//).groups[0], 'currentValue': $$.package.version}",
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      description: "Update Github URLs in YAML",
      "managerFilePatterns": ["/\\.ya?ml$/"],
      "matchStrings": [
        "https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/(?<currentValue>v?[\\d\\.]+)/"
      ],
      "datasourceTemplate": "github-releases"
    },
  ],
}
