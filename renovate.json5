{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  kubernetes: {
    managerFilePatterns: [
      '/k8s/manifests/.+\\.yaml$/',
    ],
  },
  flux: {
    managerFilePatterns: [
      '/k8s/manifests/.+\\.yaml$/',
    ],
  },
  terraform: {
    managerFilePatterns: [
      '/\\.tf$/',
    ],
  },
  packageRules: [
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["kube-prometheus-stack"],
      schedule: ["* 0 * * 0"]
    }
  ],
}
